Texture2D colorTexture     : register(t0);
Texture2D normalMapTexture : register(t1);
SamplerState colorSampler  : register(s0);

struct Light
{
    float4 pos;
    float4 color;
};

cbuffer ObjectBuffer : register(b0)
{
    row_major float4x4 model;
    row_major float4x4 normalModel;
    float4 size;
    float4 material; // x = shininess
    float4 color;
};

cbuffer SceneBuffer : register(b1)
{
    row_major float4x4 vp;
    float4 cameraPos;
    int4 lightCount;
    Light lights[10];
    float4 ambientColor;
};

struct VSOutput
{
    float4 pos      : SV_Position;
    float4 worldPos : POSITION;
    float3 tang     : TANGENT;
    float3 norm     : NORMAL;
    float2 uv       : TEXCOORD;
};

float4 ps(VSOutput pixel) : SV_Target0
{
    float3 albedo = colorTexture.Sample(colorSampler, pixel.uv).xyz;

    float3 binorm = normalize(cross(pixel.norm, pixel.tang));
    float3 localNorm = normalMapTexture.Sample(colorSampler, pixel.uv).xyz * 2.0f - float3(1.0f, 1.0f, 1.0f);

    float3 normal =
        localNorm.x * normalize(pixel.tang) +
        localNorm.y * binorm +
        localNorm.z * normalize(pixel.norm);

    normal = normalize(normal);

    float3 finalColor = ambientColor.xyz * albedo;

    for (int i = 0; i < lightCount.x; i++)
    {
        float3 lightDir = lights[i].pos.xyz - pixel.worldPos.xyz;
        float lightDist = length(lightDir);
        lightDir /= max(lightDist, 0.0001f);

        float atten = saturate(1.0f / max(lightDist * lightDist, 0.0001f));

        // Diffuse part
        finalColor += albedo * max(dot(lightDir, normal), 0.0f) * atten * lights[i].color.xyz;

        float3 viewDir = normalize(cameraPos.xyz - pixel.worldPos.xyz);
        float3 reflectDir = reflect(-lightDir, normal);
        float spec = material.x > 0.0f ? pow(max(dot(viewDir, reflectDir), 0.0f), material.x) : 0.0f;

        // Specular part
        finalColor += albedo * spec * lights[i].color.xyz;
    }

    return float4(finalColor, 1.0f);
}