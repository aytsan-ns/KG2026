Texture2D colorTexture : register(t0);
SamplerState colorSampler : register(s0);

struct VSOutput
{
    float4 pos : SV_Position;
    float2 uv  : TEXCOORD;
};

float4 ps(VSOutput pixel) : SV_Target0
{
    float3 color = colorTexture.Sample(colorSampler, pixel.uv).xyz;

    float3 sepia;
    sepia.r = dot(color, float3(0.393f, 0.769f, 0.189f));
    sepia.g = dot(color, float3(0.349f, 0.686f, 0.168f));
    sepia.b = dot(color, float3(0.272f, 0.534f, 0.131f));

    return float4(saturate(sepia), 1.0f);
}